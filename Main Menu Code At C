const char* obtener_nombre_casa(Casa_t casa) {
    if (IdiomaActual == 0 || IdiomaActual == 2) { // Español / Português
        switch (casa) {
            case IMPERIO_HIERRO:    return "El Imperio de Hierro";
            case GUARDIANES_TIERRA: return "Los Guardianes de la Tierra";
            case SINDICATO_VACIO:   return "El Sindicato del Vacio";
            default:                return "Desconocida";
        }
    } else if (IdiomaActual == 3) { // Deutsch
        switch (casa) {
            case IMPERIO_HIERRO:    return "Das Eiserne Imperium";
            case GUARDIANES_TIERRA: return "Die Erdwachter";
            case SINDICATO_VACIO:   return "Das Leere-Syndikat";
            default:                return "Unbekannt";
        }
    } else { // English
        switch (casa) {
            case IMPERIO_HIERRO:    return "The Iron Empire";
            case GUARDIANES_TIERRA: return "The Earth Guardians";
            case SINDICATO_VACIO:   return "The Void Syndicate";
            default:                return "Unknown";
        }
    }
}

