// Definición de la estructura para los personajes
typedef struct {
    int id;
    char nombre[50];
    char tipo[20];
    int hp;
    int def;
    int atk;
    int power;
} Personaje;

// Función que simula el ataque
void simular_ataque(Personaje atacante, Personaje *defensor) {
    // Fórmula de daño: (ATK + POWER) - DEF
    int daño = (atacante.atk + atacante.power) - defensor->def;
    
    // El daño mínimo siempre debe ser al menos 1
    if (daño <= 0) {
        daño = 1;
    }
    
    // Restar vida al defensor
    int hp_inicial = defensor->hp;
    defensor->hp -= daño;
    if (defensor->hp < 0) {
        defensor->hp = 0;
    }
    
    // Mostrar el resultado por pantalla
    printf("⚔️  %s (%s) ataca a %s (%s)!\n", atacante.nombre, atacante.tipo, defensor->nombre, defensor->tipo);
    printf("💥 Danio infligido: %d (Ataque total: %d vs Defensa: %d)\n", daño, (atacante.atk + atacante.power), defensor->def);
    
    if (defensor->hp == 0) {
        printf("💀 ¡%s ha sido derrotado!\n", defensor->nombre);
    } else {
        printf("❤️  %s queda con %d/%d HP.\n", defensor->nombre, defensor->hp, hp_inicial);
    }
    printf("--------------------------------------------------\n");
}

