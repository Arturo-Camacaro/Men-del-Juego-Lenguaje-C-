#include <stdio.h>
#include <stdlib.h>
#include <string.h>

#define Max_slots 3

int IdiomaActual = 0;
const char * textos [2][10] = {
    {
        "Nueva Partida",
        "Cargar Partida",
        "Estadisticas",
        "Configuracion",
        "Salir",
        "Seleccione una Opcion: ",
        "Idioma cambiado a Español",
        "Ingrese su nombre",
        "Partida Guardada",
    },
    {
        "New Game",
        "Load Game",
        "Statistics",
        "Configuration",
        "Exit",
        "Select an Option: ",
        "Language changed to English",
        "Enter your name",
        "Game Saved",
    }
};

typedef struct {
    char nombre[50];
    int puntos;
    int nivel;
} Partida;

void MostrarDatos(Partida p) {
    printf("\n---------------------------\n");
    printf(" Player: %s\n", p.nombre);
    printf(" Score:  %d\n", p.puntos);
    printf(" Level:  %d\n", p.nivel);
    printf("---------------------------\n");
}

void GuardarEnSlot(Partida p, int slot) {
    Partida todos[Max_slots] = {0}; 
    FILE *archivo = fopen("save.dat", "rb");
    if (archivo != NULL) {
        fread(todos, sizeof(Partida), Max_slots, archivo);
        fclose(archivo);
    }

    todos[slot] = p;

    archivo = fopen("save.dat", "wb");
    if (archivo != NULL) {
        fwrite(todos, sizeof(Partida), Max_slots, archivo);
        fclose(archivo);
        printf("\n%s (Slot %d)\n", textos[IdiomaActual][8], slot + 1);
    }
}

int CargarDeSlot(Partida *p, int slot) {
    Partida todos[Max_slots];
    FILE *archivo = fopen("save.dat", "rb");
    if (archivo == NULL) return 0; 

    fread(todos, sizeof(Partida), Max_slots, archivo);
    fclose(archivo);

    if (strlen(todos[slot].nombre) == 0) return 0;

    *p = todos[slot];
    return 1;
}

void MostrarMenu() {
    printf("=================================\n");
    printf(" --- AS DE PICAS - CARD GAME --- \n");
    printf("=================================\n");
    for(int i = 0; i < 5; i++) {
        printf("%d. %s\n", i + 1, textos[IdiomaActual][i]);
    }
    printf("=================================\n");
    printf("%s", textos[IdiomaActual][5]);
}


int main() {
    int opcion, slot;
    Partida partidaActual = {"Sin Nombre", 0, 0};

    do {
        MostrarMenu();
        
        if (scanf("%d", &opcion) != 1) {
            printf("\nError: Ingrese un numero.\n");
            while (getchar() != '\n'); 
            continue;
        }

        system("cls || clear");

        switch (opcion) {
            case 1: 
                printf("%s", textos[IdiomaActual][9]);
                scanf("%d", &slot);
                if(slot < 1 || slot > Max_slots) break;

                printf("%s: ", textos[IdiomaActual][7]);
                scanf("%s", partidaActual.nombre);
                partidaActual.puntos = 0; 
                partidaActual.nivel = 1;
                
                MostrarDatos(partidaActual); 
                GuardarEnSlot(partidaActual, slot - 1); 
                break;

            case 2: 
                printf("%s", textos[IdiomaActual][9]);
                scanf("%d", &slot);
                if(slot < 1 || slot > ) break;

                if (CargarDeSlot(&partidaActual, slot - 1)) {
                    MostrarDatos(partidaActual); 
                } else {
                    printf("\nSlot vacio / Empty slot.\n");
                }
                break;

            case 3:
                printf("--- %s ---\n", textos[IdiomaActual][2]);
                MostrarDatos(partidaActual);
                break;

            case 4:
                printf("0. Español\n1. English\n> ");
                scanf("%d", &IdiomaActual);
                if(IdiomaActual < 0 || IdiomaActual > 1) IdiomaActual = 0;
                printf("\n%s\n", textos[IdiomaActual][6]);
                break;

            case 5: 
                system("cls || clear");
                printf("--- RESUMEN FINAL ---\n");
                MostrarDatos(partidaActual); 
                printf("\n¡Gracias por jugar! / Bye!\n");
                break;
        }
        
        printf("\nPress Enter...");
        while (getchar() != '\n');
        getchar();
        system("cls || clear");

    } while (opcion != 5);

    return 0;
}
